    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^24.11.0",
    "@umijs/openapi": "^1.14.1",
    "@vitejs/plugin-vue": "^6.0.4",
